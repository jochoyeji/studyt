<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>성취도 기반 자기주도학습 플래너</title>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <div id="app">
        
        <main id="screen-main" class="screen active">
            <header class="header">
                <h1 id="current-month-year">--년 -월</h1>
                <button id="btn-menu" class="icon-btn" aria-label="메뉴">
                    <div class="hamburger-line"></div>
                    <div class="hamburger-line"></div>
                    <div class="hamburger-line"></div>
                </button>
            </header>
            
            <section class="stats-container">
                <div class="stat-box">
                    <span class="stat-label">평균 달성률</span>
                    <span class="stat-value" id="stat-avg">-</span>
                </div>
                <div class="stat-box">
                    <span class="stat-label">어제 달성률</span>
                    <span class="stat-value" id="stat-yesterday">-</span>
                </div>
                <div class="stat-box">
                    <span class="stat-label">연속 성취도</span>
                    <span class="stat-value" id="stat-streak">-일</span>
                </div>
            </section>

            <section id="calendar-container" class="calendar-grid">
            </section>
        </main>

        <main id="screen-timetable" class="screen">
            <header class="header">
                <button class="btn-back icon-btn">&lt;</button>
                <h2>요일별 시간표 설정</h2>
                <div class="header-placeholder"></div>
            </header>
            <section id="timetable-content" class="content-padding">
                </section>
        </main>

        <main id="screen-rewards" class="screen">
            <header class="header">
                <button class="btn-back icon-btn">&lt;</button>
                <h2>성취도 보상 목록</h2>
                <div class="header-placeholder"></div>
            </header>
            <section id="rewards-content" class="content-padding">
                </section>
        </main>

        <main id="screen-settings" class="screen">
            <header class="header">
                <button class="btn-back icon-btn" id="btn-settings-back">&lt;</button>
                <h2>설정</h2>
                <button class="btn-text hidden" id="btn-settings-cancel">취소</button>
            </header>
            <section id="settings-content" class="content-padding">
                </section>
        </main>

        <div id="menu-modal" class="modal-overlay hidden">
            <div class="modal-content square-modal">
                <button id="btn-close-menu" class="btn-close-box">X</button>
                <div class="menu-button-group">
                    <button class="menu-btn" data-target="screen-timetable">요일별 시간표 설정</button>
                    <button class="menu-btn" data-target="screen-rewards">성취도 보상 목록</button>
                    <button class="menu-btn" data-target="screen-settings">설정</button>
                </div>
            </div>
        </div>

        <div id="toast-container" class="toast hidden"></div>

        </div>

    <script src="js/app.js"></script>
    <script src="js/storage.js"></script>
    <script src="js/records.js"></script>
    <script src="js/calendar.js"></script>
</body>
</html>
