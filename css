/* 기본 초기화 및 폰트 설정 */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Malgun Gothic', 'Apple SD Gothic Neo', sans-serif;
    color: #000;
}

body {
    background-color: #e0e0e0; /* PC/태블릿에서 남는 여백 색상 */
    display: flex;
    justify-content: center;
    min-height: 100vh;
}

/* 메인 앱 컨테이너 (모바일 비율) */
#app {
    width: 100%;
    max-width: 480px;
    background-color: #ffffff;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
    box-shadow: 0 0 15px rgba(0,0,0,0.2);
}

/* 화면 전환 (SPA) 클래스 */
.screen {
    display: none;
    width: 100%;
    min-height: 100vh;
    flex-direction: column;
}
.screen.active {
    display: flex;
}

/* 공통 헤더 */
.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 20px;
    border-bottom: 2px solid #000;
}
.header h1, .header h2 {
    font-size: 1.2rem;
    font-weight: bold;
}
.header-placeholder {
    width: 24px; /* 양쪽 균형을 위한 빈 공간 */
}

/* 버튼 기본 스타일 */
button {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
}
.icon-btn {
    width: 40px;
    height: 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
}
.btn-back {
    font-size: 1.5rem;
    font-weight: bold;
}
.btn-text {
    font-weight: bold;
    padding: 5px 10px;
    border: 1px solid #000;
}

/* 햄버거 아이콘 */
.hamburger-line {
    width: 24px;
    height: 3px;
    background-color: #000;
}

/* 상단 통계 박스 영역 */
.stats-container {
    display: flex;
    justify-content: space-between;
    padding: 15px 20px;
    gap: 10px;
}
.stat-box {
    flex: 1;
    border: 1px solid #000;
    padding: 10px 5px;
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
}
.stat-label {
    font-size: 0.8rem;
    word-break: keep-all;
}
.stat-value {
    font-weight: bold;
    font-size: 1rem;
}

/* 임시 캘린더 영역 */
.calendar-placeholder {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    border: 1px dashed #000;
    margin: 0 20px 20px 20px;
}

/* 내부 콘텐츠 여백 */
.content-padding {
    padding: 20px;
}

/* --- 모달 (공통) --- */
.modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.6); /* 배경 어둡게 */
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 100;
}
.modal-overlay.hidden {
    display: none;
}

/* 햄버거 메뉴 모달 창 (전체 화면의 75% 정사각형 형태) */
.square-modal {
    width: 75%;
    aspect-ratio: 1 / 1;
    background-color: #fff;
    border: 2px solid #000;
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 20px;
}
.btn-close-box {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 30px;
    height: 30px;
    border: 2px solid #000;
    background-color: #fff;
    font-weight: bold;
    font-size: 1.2rem;
    display: flex;
    justify-content: center;
    align-items: center;
}
.menu-button-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 15px;
    margin-top: 30px;
}
.menu-btn {
    border: 2px solid #000;
    padding: 15px;
    font-weight: bold;
    text-align: center;
    background-color: #fff;
}
.menu-btn:active {
    background-color: #f0f0f0;
}

/* --- 토스트 UI --- */
.toast {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    background-color: #fff;
    color: #000;
    border: 2px solid #000;
    padding: 10px 20px;
    font-size: 0.9rem;
    font-weight: bold;
    z-index: 200;
    opacity: 1;
    transition: opacity 0.3s ease;
    white-space: nowrap;
}
.toast.hidden {
    display: none;
    opacity: 0;
}
.toast.error {
    color: red;
    border-color: red;
}

/* --- 2단계 추가: 캘린더 스타일 --- */
.calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
    margin: 0 10px 20px 10px;
    flex: 1;
}

.cal-header-day {
    text-align: center;
    font-weight: bold;
    font-size: 0.9rem;
    padding: 10px 0;
}

.cal-day {
    background-color: #fff;
    border: 1px solid #000;
    aspect-ratio: 1 / 1; /* 정사각형 비율 유지 */
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 5px;
    cursor: pointer;
}

.cal-day.today {
    border: 3px solid #000; /* 오늘 날짜 두꺼운 테두리 */
    font-weight: bold;
}

.grade-display {
    margin-top: auto;
    font-size: 1.2rem;
    font-weight: bold;
    color: #000;
}

/* --- 2단계 추가: 순공 시간 입력 모달 --- */
/* 전체 화면의 40%를 차지하는 창 넓이 설정 */
.study-modal-box {
    width: 40%;
    min-width: 160px; /* 모바일에서 글자가 깨지지 않도록 최소 너비 보장 */
    background-color: #fff;
    border: 2px solid #000;
    padding: 20px 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    text-align: center;
}

.study-modal-box h3 {
    font-size: 0.9rem;
    word-break: keep-all;
}

.time-input-group {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 5px;
    font-size: 0.9rem;
}

.time-input-group input {
    width: 40px;
    text-align: right;
    border: 1px solid #000;
    padding: 3px;
    font-size: 1rem;
}

/* Chrome, Safari, Edge, Opera에서 input type="number"의 화살표 제거 */
.time-input-group input::-webkit-outer-spin-button,
.time-input-group input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

.error-text {
    color: red;
    font-size: 0.8rem;
    margin-top: -5px;
}
